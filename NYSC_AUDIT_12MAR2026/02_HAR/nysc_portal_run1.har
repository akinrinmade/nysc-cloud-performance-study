       -webkit-transition: all 0.5s ease;\r\n                -moz-transition: all 0.5s ease;\r\n                -o-transition: all 0.5s ease;\r\n                transition: all 0.5s ease;\r\n            }\r\n\r\n        .content {\r\n            margin-left: 10px;\r\n            text-align: justify;\r\n            width: 75%;\r\n            float: left;\r\n            line-height: 20px;\r\n            padding: 10px;\r\n        }\r\n\r\n        .Remobilise {\r\n            float: left;\r\n            height: 110px;\r\n            width: 110px;\r\n            box-shadow: 1px 2px 3px #ccc;\r\n            border: 1px solid #009900;\r\n            font-weight: bold;\r\n            font-size: 15px;\r\n            cursor: pointer;\r\n            text-align: center;\r\n            font-weight: bold;\r\n            color: #fff;\r\n            -moz-border-radius: 50%;\r\n            -webkit-border-radius: 50%;\r\n            border-radius: 50%;\r\n            text-shadow: 0 1px 1px rgba(0,0,0,.3);\r\n            background-color: #007700;\r\n        }\r\n\r\n            .Remobilise:hover {\r\n                background-color: #00aa00;\r\n                -webkit-transition: all 0.5s ease;\r\n                -moz-transition: all 0.5s ease;\r\n                -o-transition: all 0.5s ease;\r\n                transition: all 0.5s ease;\r\n            }\r\n\r\n        .Revalidate {\r\n            float: left;\r\n            height: 110px;\r\n            width: 110px;\r\n            box-shadow: 1px 2px 3px #ccc;\r\n            border: 1px solid #009900;\r\n            font-weight: bold;\r\n            font-size: 15px;\r\n            cursor: pointer;\r\n            text-align: center;\r\n            font-weight: bold;\r\n            color: #fff;\r\n            -moz-border-radius: 50%;\r\n            -webkit-border-radius: 50%;\r\n            border-radius: 50%;\r\n            text-shadow: 0 1px 1px rgba(0,0,0,.3);\r\n            background-color: #007700;\r\n        }\r\n\r\n            .Revalidate:hover {\r\n                background-color: #00aa00;\r\n                -webkit-transition: all 0.5s ease;\r\n                -moz-transition: all 0.5s ease;\r\n                -o-transition: all 0.5s ease;\r\n                transition: all 0.5s ease;\r\n            }\r\n\r\n        .clear {\r\n            clear: both;\r\n            margin-bottom: 7px;\r\n        }\r\n\r\n        .registerMob {\r\n            background: rgb(226, 195, 74);\r\n            border-bottom: 2px solid rgb(198, 168, 53);\r\n            padding: 0 8px;\r\n            border-radius: 3px;\r\n            color: #005500;\r\n        }\r\n\r\n            .registerMob:hover {\r\n                background: rgb(211, 168, 0);\r\n                border-bottom: 2px solid rgb(247, 215, 90);\r\n                color: #003300;\r\n                -webkit-transition: all 500ms;\r\n                -moz-transition: all 500ms;\r\n                -ms-transition: all 500ms;\r\n                -o-transition: all 500ms;\r\n                transition: all 500ms;\r\n            }\r\n\r\n        .registerRemob {\r\n            background: rgb(201,102,102);\r\n            border-bottom: 2px solid rgb(183, 86, 86);\r\n            padding: 0 8px;\r\n            border-radius: 3px;\r\n            color: #f6f6f6;\r\n        }\r\n\r\n            .registerRemob:hover {\r\n                background: rgb(153,49,49);\r\n                border-bottom: 2px solid rgb(201,102,102);\r\n                color: #fff;\r\n                -webkit-transition: all 500ms;\r\n                -moz-transition: all 500ms;\r\n                -ms-transition: all 500ms;\r\n                -o-transition: all 500ms;\r\n                transition: all 500ms;\r\n            }\r\n\r\n            .red-tooltip + .tooltip > .tooltip-inner {\r\n                background-color: #2b943a;\r\n                z-index:1000;\r\n            }\r\n\r\n       \r\n    </style>\r\n\r\n\r\n    <style type=\"text/css\">\r\n        /*header of 1st demo*/\r\n        .mypets {\r\n            cursor: pointer;\r\n            padding: 2px 5px;\r\n            height: 25px;\r\n            font-size: 16px;\r\n            font-weight: normal;\r\n            color: #fff;\r\n            border: 1px solid #53BB60;\r\n            background-color: #006600;\r\n            text-shadow: 0 1px 1px rgba(0,0,0,.3);\r\n            -webkit-border-radius: 0.6em 0 0 0.6em;\r\n            -moz-border-radius: 0.6em 0 0 0.6em;\r\n            border-radius: 0.6em 0 0 0.6em;\r\n        }\r\n\r\n        .openpet { /*class added to contents of 1st demo when they are open*/\r\n            background-color: Yellow;\r\n            color: #006600;\r\n            height: 25px;\r\n            border: 1px solid #E8E800;\r\n            text-shadow: 0 1px 1px rgba(0,0,0,.3);\r\n            -webkit-border-radius: 0.6em 0 0 0.6em;\r\n            -moz-border-radius: 0.6em 0 0 0.6em;\r\n            border-radius: 0.6em 0 0 0.6em;\r\n        }\r\n\r\n        .technology { /*header of 2nd demo*/\r\n            cursor: hand;\r\n            cursor: pointer;\r\n            font: bold 11px Verdana;\r\n            margin: 10px 0;\r\n        }\r\n\r\n\r\n        .openlanguage { /*class added to contents of 2nd demo when they are open*/\r\n            color: green;\r\n        }\r\n\r\n        .closedlanguage { /*class added to contents of 2nd demo when they are closed*/\r\n            color: red;\r\n        }\r\n    </style>\r\n\r\n    <style>\r\n        div .section {\r\n            margin-top: -45px;\r\n            margin-bottom: -45px;\r\n        }\r\n    </style>\r\n\r\n    \r\n    <style type=\"text/css\">\r\n        /*Example CSS for the two demo scrollers*/\r\n\r\n        #pscroller1 {\r\n            width: 250px;\r\n            height: 150px;\r\n            border: 1px solid black;\r\n            padding: 5px;\r\n            background-color: #f4f4f4;\r\n        }\r\n        /*\r\n#pscroller2{\r\nwidth: 350px;\r\nheight: 20px;\r\nborder: 1px solid black;