         <div class=\"pricing-plan col-lg-12\">\r\n                        <!-- Pricing Plan Ribbon -->\r\n                        <div class=\"ribbon-wrapper\" style=\"display: none\">\r\n                            <div class=\"price-ribbon ribbon-red\">Popular</div>\r\n                        </div>\r\n                        <h2 class=\"pricing-plan-title\">F.A.Qs</h2>\r\n                        <a href=\"FAQ.aspx\">\r\n                            <img src=\"img/faq.png\" class=\"img-responsive\" alt=\"Frequently Asked Questions\">\r\n                           \r\n                        </a>\r\n                    </div>\r\n                </div>\r\n                <!-- End Pricing Plans Wrapper -->\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <!-- End Pricing Table -->\r\n\r\n    <!-- Testimonials -->\r\n    <div class=\"section\">\r\n        <div class=\"container\">\r\n            <h2>Important Information</h2>\r\n            <div class=\"row\">\r\n                <!-- Testimonial -->\r\n                <div class=\"testimonial col-md-4 col-sm-6\">\r\n                    <!-- Author Photo -->\r\n                    <div class=\"author-photo\" style=\"display: none\">\r\n                        <a target=\"_blank\" href=\"VerifySenateLists.aspx\">\r\n                            <img src=\"img/list.png\" alt=\"Click here to check the senate list for your institution\"></a>\r\n                    </div>\r\n                    <div class=\"testimonial-bubble\">\r\n                        <blockquote>\r\n                            <!-- Quote -->\r\n                            <p class=\"quote\">\r\n                                <a target=\"_blank\" href=\"VerifySenateLists.aspx\">Check Senate List or its equivalents</a>\r\n                            </p> \r\n                            <p class=\"quote\">\r\n                                <a target=\"_blank\" href=\"CheckInstitutionCoursesPCMs.aspx\">View Graduation List</a>\r\n             